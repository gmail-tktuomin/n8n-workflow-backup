    {
      "parameters": {
        "jsCode": "/**\n * n8n Code Node — Trello List: Extract all listIDs and listNames\n * Set mode: Run Once for All Items\n */\n\nconst first = $input.first().json;\nlet items = Array.isArray(first) ? first : (first?.data ?? first?.lists ?? null);\nif (!items) {\n  items = $input.all().map((i) => i.json);\n}\n\nconst result = items.map((item) => ({\n  listID: item.id,\n  listName: item.name,\n}));\n\nreturn result.map((item) => ({ json: item }));\n"
      },
