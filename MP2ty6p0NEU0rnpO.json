  "name": "Trello status to email",
  "nodes": [
    {
      "parameters": {
        "jsCode": "/**\n * n8n Code Node — Format grouped Trello data as HTML for Gmail\n * Set mode: Run Once for All Items\n */\n\nconst input = $input.first().json;\nconst groups = Array.isArray(input) ? input : (input.data ?? input.groups ?? $input.all().map((i) => i.json));\n\nfunction escapeHtml(str) {\n  if (str == null) return '';\n  return String(str)\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;');\n}\n\nconst sections = groups.map((group) => {\n  const listName = escapeHtml(group.listName || 'Untitled');\n  const items = (group.items || []).map(\n    (item) =>\n      `<tr>\n        <td style=\"padding: 8px 12px; border-bottom: 1px solid #e8e8e8;\">\n          <a href=\"${escapeHtml(item.url || '#')}\" style=\"color: #0066cc; text-decoration: none;\">${escapeHtml(item.name || 'Untitled')}</a> <span>${escapeHtml(item.userNames || 'Untitled')}</span>\n        </td>\n      </tr>`\n  ).join('');\n\n  return `\n    <div style=\"margin-bottom: 24px;\">\n      <h2 style=\"margin: 0 0 12px 0; font-size: 18px; font-weight: 600; color: #172b4d;\">${listName}</h2>\n      <table style=\"width: 100%; border-collapse: collapse; background: #fafafa; border-radius: 8px; overflow: hidden;\">\n        ${items}\n      </table>\n    </div>\n  `;\n}).join('');\n\nconst html = `\n<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n</head>\n<body style=\"margin: 0; padding: 24px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 15px; line-height: 1.5; color: #333;\">\n  <div style=\"max-width: 600px; margin: 0 auto;\">\n    <h1 style=\"margin: 0 0 24px 0; font-size: 22px; font-weight: 600; color: #172b4d;\">Trello Board Update</h1>\n    ${sections}\n    <p style=\"margin-top: 24px; font-size: 13px; color: #6b778c;\">— Sent via Automagic</p>\n  </div>\n</body>\n</html>\n`.trim();\n\nreturn [{ json: { html } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1936,
        0
      ],
      "id": "77b5d4ca-d51e-4c29-a038-497e766a0f95",
      "name": "Format html"
    },
    {
      "parameters": {
        "jsCode": "/**\n * n8n Code Node — Group Trello items by listName\n * Output: one item per list, each with listName and items[] (all fields preserved)\n * Set mode: Run Once for All Items\n */\n\nconst input = $input.first().json;\nconst items = Array.isArray(input) ? input : (input.data ?? input.items ?? $input.all().map((i) => i.json));\n\nconst groups = {};\nfor (const item of items) {\n  const key = item.listName ?? item.name ?? 'Unknown';\n  if (!groups[key]) groups[key] = [];\n  groups[key].push({ ...item });\n}\n\nconst result = Object.entries(groups).map(([listName, items]) => ({\n  json: {\n    listName,\n    items,\n  },\n}));\n\nreturn result;\n"
      },
